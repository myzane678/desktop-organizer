{
  "name": "desktop-organizer",
  "version": "1.0.2",
  "description": "Windows 桌面整理工具 - 按功能自动分类、预览并重排桌面图标",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "verify:classifier": "node scripts/verify-classifier.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis portable"
  },
  "keywords": [
    "desktop",
    "organizer",
    "electron",
    "windows"
  ],
  "author": "ROG",
  "license": "MIT",
  "build": {
    "appId": "com.myzane678.desktop-organizer",
    "productName": "桌面整理",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "桌面整理"
    },
    "asarUnpack": [
      "electron/*.ps1"
    ]
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "windows-shortcuts": "^0.1.6"
  }
}
